PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Аль нэгийн нэрээр хангалттай (`MONGO_URI` таны .env-д түгээмэл)
MONGODB_URI=mongodb://127.0.0.1:27017/dms
# MONGO_URI=mongodb://127.0.0.1:27017/dms

# Optional: Upstash or local Redis for refresh token rotation / rate limit
REDIS_URL=

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

WEST_LOGIN_URL=http://west.edu.mn:3000/api/v1/students/login

# Кампусын «өдөр», зочны цагийн журмыг тооцох IANA бүс (Жаргалант дотуур байр — ихэвчлэн Монголын нэгдсэн цаг Asia/Ulaanbaatar)
# Өөр бүс шаардлагатай бол жишээ нь: Asia/Hovd
CAMPUS_DAY_TIMEZONE=Asia/Ulaanbaatar

# QPay — merchant.qpay.mn / sandbox дээрээс өөрийн Client ID, Secret, Invoice code авна
# Анхаар: анхны sandbox TEST_MERCHANT/WBDUzy8n олон орчинд хүчингүй болсон (401 AUTHENTICATION_FAILED).
# Түлхүүргүй зөвхөн local туршилт (NODE_ENV=development): QPAY_MOCK=true
# QPAY_MOCK=true
QPAY_BASE_URL=https://merchant.qpay.mn
QPAY_CLIENT_ID=GZ_TEST
QPAY_CLIENT_SECRET=WBDUzy8n
QPAY_INVOICE_CODE=GZTEST_INVOICE
# Интернетаас webhook авах бол (localhost-д ихэвчлэн ажиллахгүй — QR + «Шалгах» ашиглана)
# BACKEND_PUBLIC_URL=https://таны-домэйн/api-суурь
